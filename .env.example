# Render will provide PORT automatically
PORT=8080

# Supabase PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.your_project_ref
SPRING_DATASOURCE_PASSWORD=YOUR_SUPABASE_PASSWORD

# CORS
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-url.vercel.app

# App URLs and storage
APP_PUBLIC_BASE_URL=https://your-backend-url.onrender.com
APP_UPLOAD_DIRECTORY=uploads

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
